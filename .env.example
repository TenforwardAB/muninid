HOST=0.0.0.0
PORT=8080
OIDC_ISSUER=http://localhost:8080
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# At least one 32+ character secret. Node IDP expects two 64+ char keys;
# this Go base currently signs its own idp.sid cookie with the first key.
OIDC_COOKIE_KEYS=change-me-change-me-change-me-change-me

# Must match the Node IDP value if you want to read existing enc:v1 secrets.
IDP_SECRET_ENCRYPTION_KEY=change-me-change-me-change-me-change-me

# First-party client redirect/logout domains that skip consent prompts.
OIDC_TRUSTED_CONSENT_DOMAINS=solutrix.io,mailtrix.eu

DATABASE_URL=postgres://postgres:postgres@localhost:5432/solutrix?sslmode=disable
WILDDUCK_API_URL=http://localhost:8080
WILDDUCK_API_TOKEN=change-me

# Global admin routes: /api/global/admin/*
ADMIN_API_KEY=change-me

ENABLE_GUI=false
MASTER_USER=idp_admin
MASTER_PASSWORD=change-me
